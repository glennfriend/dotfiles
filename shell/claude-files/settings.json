{
  "env": {
    "EDITOR": "vim"
  },
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git --no-pager log origin/master..HEAD --oneline)",
      "Bash(git --no-pager diff origin/master...HEAD --stat)",
      "Bash(git --no-pager diff --cached)",
      "Bash(git -C /var/www/cl/ava:*)",
      "Bash(git -C /var/www/cl/ava-client:*)",
      "Bash(git -C /var/www/cl/samurai-world-backend:*)",
      "Bash(git -C /var/www/cl/samurai-world-client:*)",
      "Bash(yarn eslint:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn test:*)",
      "Bash(yarn type-check:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier --check:*)",
      "Bash(yarn prettier --write:*)",
      "Bash(./node_modules/.bin/prettier --write:*)",
      "Bash(./node_modules/.bin/prettier --check:*)",
      "Bash(./node_modules/.bin/eslint:*)",
      "Bash(./node_modules/.bin/tsc:*)",
      "Bash(source ~/.nvm/nvm.sh:*)",
      "Bash(nvm use:*)",
      "Bash(composer show:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Read(~/.claude)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/status-line.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "skipDangerousModePermissionPrompt": false
}
