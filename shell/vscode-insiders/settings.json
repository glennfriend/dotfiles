{
    "// search.followSymlinks": "專案中允許搜尋外部連結的檔案? 但是, 無效果",
    "search.followSymlinks": true,
    "github.copilot.chat.localeOverride": "zh-TW",
    "accessibility.voice.speechLanguage": "zh-TW",
    "plantuml.render": "PlantUMLServer",
    "plantuml.server": "http://127.0.0.1:8888/",
    "// editor.fontFamily": "Noto Sans Mono CJK TC 可以對齊 中文字與空白",
    "editor.fontFamily": "'Hack', 'Droid Sans Mono', monospace",
    "chat.tools.terminal.autoApprove": {
        "/^docker compose exec php php -l [.a-zA-Z0-9][./a-zA-Z0-9]*\\.php$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "chat.tools.urls.autoApprove": {
        "https://uptimerobot.com": {
            "approveRequest": false,
            "approveResponse": true
        }
    },
    "chat.tools.terminal.outputLocation": "chat",
    "chat.viewSessions.orientation": "stacked"
}
